# ─── Database ─────────────────────────────────────────────────────────────────
# App connection (used at runtime — RLS active via withUserContext)
DATABASE_URL="postgresql://mahara_owner:mahara_dev_password@localhost:5432/mahara"

# Docker Compose: owner credentials (used to start postgres container)
POSTGRES_OWNER_USER="mahara_owner"
POSTGRES_OWNER_PASSWORD="mahara_dev_password"

# ─── Auth.js ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
AUTH_SECRET="replace-with-32-char-random-string"
AUTH_URL="http://localhost:3000"

# ─── Google OAuth (optional in dev — leave blank to disable) ─────────────────
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=""

# ─── File Storage (Cloudflare R2) ─────────────────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="mahara-dev"
R2_PUBLIC_URL=""

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Vercel Cron (optional) ───────────────────────────────────────────────────
CRON_SECRET=""
